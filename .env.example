# Supabase
# 1) sql/001_supabase_schema.sql 내용을 Supabase SQL Editor에서 먼저 실행합니다.
# 2) Project Settings > API에서 URL과 service role key를 복사합니다.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Embedding
# JINA_API_KEY가 있으면 jina-embeddings-v3를 사용합니다.
# 없으면 로컬 검증용 해시 임베딩을 사용합니다.
JINA_API_KEY=
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024

# Chat model - OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=RAG Public Document Assignment

# Re-rank
# cohere: COHERE_API_KEY + rerank-multilingual-v3.0
# jina: JINA_API_KEY + jina-reranker-v2-base-multilingual
# local: API 없이 토큰 겹침 점수로 재정렬
RERANK_PROVIDER=cohere
COHERE_API_KEY=your-cohere-api-key
RERANK_MODEL=rerank-multilingual-v3.0

# Server
HOST=127.0.0.1
PORT=3000
